generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  displayName    String?
  avatarUrl      String?
  bio            String?
  provider       String   @default("email")
  providerId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions        Session[]
  settings        UserSettings?
  profiles        SessionProfile[]
  quizResults     QuizResult[]
  gamification    Gamification?
  achievements    Achievement[]
  matchesInitiated UserMatch[] @relation("Initiator")
  matchesReceived  UserMatch[] @relation("Matched")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  duration  Int
  intensity Int      @default(3)
  profileId String?
  mood      String?
  notes     String?
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  profile SessionProfile? @relation(fields: [profileId], references: [id])

  @@map("sessions")
}

model UserSettings {
  userId              String  @id
  activeDuration      Int     @default(25)
  restDuration        Int     @default(5)
  intensityMode       Boolean @default(false)
  tone                String  @default("teasing")
  lockInMode          Boolean @default(false)
  cycles              Int     @default(4)
  infiniteCycles      Boolean @default(false)
  soundEnabled        Boolean @default(true)
  notificationsEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

model SessionProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  activeDuration Int
  restDuration   Int
  cycles         Int
  infiniteCycles Boolean
  tone           String
  intensityMode  Boolean
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]

  @@map("session_profiles")
}

model QuizQuestion {
  id       String @id @default(cuid())
  category String
  question String
  options  String

  @@map("quiz_questions")
}

model QuizResult {
  id               String   @id @default(cuid())
  userId           String
  createdAt        DateTime @default(now())
  scores           String
  dominantTrait    String
  rolePreference   String
  kinks            String
  compatibilityType String

  user User @relation(fields: [userId], references: [id])

  @@map("quiz_results")
}

model Prompt {
  id        String @id @default(cuid())
  tone      String
  phase     String
  intensity Int
  content   String

  @@map("prompts")
}

model Gamification {
  userId          String  @id
  streak          Int     @default(0)
  longestStreak   Int     @default(0)
  totalSessions   Int     @default(0)
  totalTime       Int     @default(0)
  level           Int     @default(1)
  xp              Int     @default(0)
  lastSessionDate String?

  user User @relation(fields: [userId], references: [id])

  @@map("gamification")
}

model Achievement {
  id             String @id @default(cuid())
  userId         String
  achievementKey String
  name           String
  description    String
  icon           String
  unlockedAt     String

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementKey])
  @@map("achievements")
}

model UserMatch {
  id                String   @id @default(cuid())
  userId            String
  matchedUserId     String
  compatibilityScore Float
  matchDetails      String
  createdAt         DateTime @default(now())

  initiator User @relation("Initiator", fields: [userId], references: [id])
  matched   User @relation("Matched", fields: [matchedUserId], references: [id])

  @@unique([userId, matchedUserId])
  @@map("user_matches")
}
