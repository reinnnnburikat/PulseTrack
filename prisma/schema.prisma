generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  displayName String?
  avatarUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  settings       UserSettings?
  profiles       SessionProfile[]
  quizResults    QuizResult[]
  gamification   Gamification?
  achievements   Achievement[]
  matchesInitiated UserMatch[] @relation("Initiator")
  matchesReceived  UserMatch[] @relation("Matched")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  duration  Int
  intensity Int      @default(3)
  profileId String?
  notes     String?
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  profile SessionProfile? @relation(fields: [profileId], references: [id])
}

model UserSettings {
  userId          String  @id
  activeDuration  Int     @default(25)
  restDuration    Int     @default(5)
  intensityMode   Boolean @default(false)
  tone            String  @default("teasing")
  lockInMode      Boolean @default(false)
  cycles          Int     @default(4)
  infiniteCycles  Boolean @default(false)
  soundEnabled    Boolean @default(true)
  notificationsEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
}

model SessionProfile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  activeDuration Int
  restDuration   Int
  cycles         Int
  infiniteCycles Boolean
  tone           String
  intensityMode  Boolean
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]
}

model QuizQuestion {
  id       String @id @default(cuid())
  category String
  question String
  options  String // JSON string of { label: string; scores: Record<string, number> }[]
}

model QuizResult {
  id               String   @id @default(cuid())
  userId           String
  createdAt        DateTime @default(now())
  scores           String   // JSON Record<string, number>
  dominantTrait    String
  rolePreference   String
  kinks            String   // JSON string[]
  compatibilityType String

  user User @relation(fields: [userId], references: [id])
}

model Prompt {
  id        String @id @default(cuid())
  tone      String
  phase     String
  intensity Int
  content   String
}

model Gamification {
  userId          String  @id
  streak          Int     @default(0)
  longestStreak   Int     @default(0)
  totalSessions   Int     @default(0)
  totalTime       Int     @default(0)
  level           Int     @default(1)
  xp              Int     @default(0)
  lastSessionDate String?

  user User @relation(fields: [userId], references: [id])
}

model Achievement {
  id             String @id @default(cuid())
  userId         String
  achievementKey String
  name           String
  description    String
  icon           String
  unlockedAt     String

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementKey])
}

model UserMatch {
  id               String   @id @default(cuid())
  userId           String
  matchedUserId    String
  compatibilityScore Float
  matchDetails     String   // JSON
  createdAt        DateTime @default(now())

  initiator User @relation("Initiator", fields: [userId], references: [id])
  matched   User @relation("Matched", fields: [matchedUserId], references: [id])

  @@unique([userId, matchedUserId])
}
